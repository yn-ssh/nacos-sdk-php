{
    "name": "nacos/nacos-sdk-php",
    "description": "PHP SDK for Nacos service discovery and configuration",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": ">=7.2",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^1.1",
        "symfony/options-resolver": "^5.0 || ^6.0",
        "grpc/grpc": "^1.30",
        "google/protobuf": "^3.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "mockery/mockery": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nacos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nacos\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php"
    }
}